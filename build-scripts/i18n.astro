---
// multilanguage content switcher
// generated by node-solve-urls.ts
import { Language, Language_html, Language_current } from './i18n';

Language_html.forEach((l)=>{
	if(!Astro.slots.has(l))
		console.warn(
			"⚠️ [M] Missing language '"+l+"' slot!\n"+
			"Path: "+Astro.url.pathname+"\n"
		);
});
---
<!--<Language-switch> -->
{(Language_current==Language.PT_BR)&&<slot name="pt-br"/>}
{(Language_current==Language.EN_US)&&<slot name="en-us"/>}
<!-- </Language-switch> -->